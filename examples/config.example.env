# Agent Governance Kit example configuration.
# Copy values into your shell profile, direnv, systemd user unit, or private
# machine-local environment file. Do not commit real secrets or private host data.

export AGK_HOOK_MODE=enforce
export AGK_INSTALL_ROOT="$HOME/.codex/agent-governance-kit"
export AGK_STATE_DIR="$HOME/.codex/agent-governance-kit/state"

# Colon-separated directories searched for journal or manifest evidence.
# Relative paths are resolved against the Git root and current working directory.
export AGK_JOURNAL_DIRS="worklog:docs:manifests"

# Colon-separated path markers and suffixes treated as protected artifacts.
export AGK_PROTECTED_PATHS=".env:.ssh/:auth.json:models/:data/:logs/:tmp/:exports/:research_eval/"

# Optional research grace policy for work-in-progress analysis files.
export AGK_RESEARCH_GRACE_ROOTS=""
export AGK_RESEARCH_GRACE_PREFIXES="docs/research/:experiments/:analysis/"
export AGK_RESEARCH_DIRTY_GRACE_HOURS=24

# Pre-commit can be set to warning mode while adopting the toolkit.
export AGK_PRE_COMMIT_WARN_ONLY=0

# Stop-hook handling for material but non-red-zone work: off, warn, or enforce.
export AGK_MATERIAL_CLOSEOUT_MODE=warn

# Journal helper default path. Leave empty to use ./worklog/YYYY-MM-DD-domain.md.
export AGK_DEFAULT_JOURNAL=""

# Optional session marker embedded in journal/manifest evidence.
export AGK_SESSION_ID=""

# Set to 1 only for private journals where hostnames and absolute paths are OK.
export AGK_JOURNAL_INCLUDE_LOCAL=0
