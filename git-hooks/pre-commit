#!/bin/sh
# Agent Governance Kit pre-commit wrapper.
set -eu

hook_self_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

if command -v git >/dev/null 2>&1; then
  repo="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
else
  repo="$(pwd)"
fi

script="$repo/git-hooks/agk_pre_commit.py"
if [ ! -x "$script" ]; then
  script="$hook_self_dir/agk_pre_commit.py"
fi
if [ ! -x "$script" ]; then
  script="$HOME/.codex/agent-governance-kit/git-hooks/agk_pre_commit.py"
fi

python3 "$script" --repo "$repo"
status=$?
if [ "$status" -ne 0 ]; then
  exit "$status"
fi

chained_hook="$hook_self_dir/pre-commit.bak-agk"
if [ -x "$chained_hook" ]; then
  "$chained_hook"
fi

exit 0
